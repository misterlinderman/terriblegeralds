# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/terriblegeralds?retryWrites=true&w=majority

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=http://localhost:3001/api
AUTH0_CLIENT_ID=your-spa-client-id

# Comma-separated admin emails allowed to access /api/admin/*
ADMIN_EMAILS=you@example.com,other@example.com

# Production only — Vercel frontend URL
CLIENT_URL=https://terriblegeralds.vercel.app

# Contact form email notifications (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_NOTIFICATION_EMAIL=terriblegeralds@gmail.com
EMAIL_FROM=Terrible Gerald's Pizza <inquiries@terriblegeralds.com>

# Catering travel radius (defaults: 4924 Grant St, Omaha — 40 miles)
# CATERING_ORIGIN_LAT=41.2876
# CATERING_ORIGIN_LNG=-96.0458
# CATERING_MAX_DISTANCE_MILES=40
